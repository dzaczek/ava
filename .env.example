# ── Twilio Voice ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+48xxxxxxxxx       # your Twilio virtual number

# ── Signal – self-hosted messaging ───────────────────────────────────────────
SIGNAL_CLI_URL=http://signal-cli:8080
SIGNAL_SENDER_NUMBER=+48xxxxxxxxx     # number registered in signal-cli (bot number)
SIGNAL_RECIPIENT=+48xxxxxxxxx         # your personal Signal number

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o                   # gpt-4o-mini = cheaper, slightly less capable

# ── ElevenLabs TTS ────────────────────────────────────────────────────────────
# Leave blank to fall back to OpenAI TTS → Twilio Polly
ELEVENLABS_API_KEY=
# Single multilingual voice ID – browse at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=WAhoMTNdLdMoq1j3wf3I
# Model: eleven_multilingual_v2 (best quality) or eleven_turbo_v2_5 (faster)
ELEVENLABS_MODEL=eleven_multilingual_v2
# OpenAI TTS fallback voice: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=nova

# ── Owner info & AVA behaviour ───────────────────────────────────────────────
# Injected into the system prompt as "about the owner" context.
# Include personal details so AVA can handle calls naturally.
OWNER_CONTEXT=The phone owner is [Your Name]. \
Birthday: [DD Month YYYY]. \
Working hours: Monday–Friday, 9:00–17:00 CET. \
Expected calls: clients asking about project status, suppliers confirming deliveries, IT team reporting infrastructure issues. \
IT/infrastructure emergencies: always treat as HIGH priority and note as urgent callback. \
Recruiters and sales calls: politely thank them and end the call. \
Callback policy: "The owner will call back as soon as possible during working hours."

# ── STT / language ───────────────────────────────────────────────────────
# Default Twilio STT language for the first Gather (before language detection kicks in).
# Set to the language most callers speak: pl-PL, de-DE, en-US, etc.
DEFAULT_STT_LANG=en-US

# ── Signal notification language ──────────────────────────────────────────
# Language for Signal messages (notifications, summaries): pl / en
SIGNAL_LANG=en

# ── Infrastructure ────────────────────────────────────────────────────────────
# Choose how AVA is exposed to the internet (Docker Compose profile).
# Set to "caddy" (Caddy + Let's Encrypt) or "tunnel" (Cloudflare Tunnel).
COMPOSE_PROFILES=caddy

# Public HTTPS URL that Twilio can reach to fetch TTS audio files.
PUBLIC_URL=https://your-domain.com

# ── Caddy profile (COMPOSE_PROFILES=caddy) ───────────────────────────────────
# Domain for Caddy HTTPS certificate (used in Caddyfile).
DOMAIN=your-domain.com

# ── Cloudflare Tunnel profile (COMPOSE_PROFILES=tunnel) ──────────────────────
# Token from Cloudflare Zero Trust dashboard → Networks → Tunnels.
CLOUDFLARE_TUNNEL_TOKEN=

# Path to contacts file (default: /data/contacts.json)
# CONTACTS_FILE_PATH=/data/contacts.json
